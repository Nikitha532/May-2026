class Solution:
    def findThePrefixCommonArray(self, A: List[int], B: List[int]) -> List[int]:
        #Brute force
        '''
        n = len(A)
        arr = []

        for currentindex in range(n) :
            commoncount = 0
            for A_index in range(currentindex + 1):
                for B_index in range(currentindex + 1) :
                    if A[A_index] == B[B_index] :
                        commoncount += 1
                        break
            arr.append(commoncount)
        return arr'''

        #optimal - frequency count
        n = len(A)
        arr = []
        frequency = [0] * (n+1)
        count = 0 

        for i in range(n) :
            frequency[A[i]] += 1
            if frequency[A[i]] == 2 :
                count += 1
            frequency[B[i]] += 1
            if frequency[B[i]] == 2 :
                count += 1
            arr.append(count)
        return arr
