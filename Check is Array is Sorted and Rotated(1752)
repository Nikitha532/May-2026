class Solution(object):
    def check(self, nums):
        """
        :type numas: List[int]
        :rtype: bool
        """

        #brute force
        '''
        n = len(nums)

        for i in range(n) :
            rotated = nums[i:] + nums[:i]
            isSorted = True

            for j in range(n-1) :
                if rotated[j] > rotated[j+1] :
                    isSorted = False
            if isSorted:
                return True
        return False'''

        #optimal
        n = len(nums)
        count = 0

        for i in range(n) :
            if nums[i] > nums[(i+1)%n] :
                count += 1

        return count <= 1
