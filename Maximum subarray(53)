class Solution:
    def maxSubArray(self, nums: List[int]) -> int:
        
        #brute force
        '''
        n = len(nums)
        maxsum = nums[0]
        for i in range(n) :
            currentsum = 0
            for j in range(i, n) :
                currentsum += nums[j]
                maxsum = max(maxsum, currentsum)
        return maxsum'''

        #optimal - kadanes algorithm
        n = len(nums)
        currentsum = nums[0]
        maxsum = nums[0]
        for i in range(1, n) :
            currentsum = max(nums[i], currentsum + nums[i])
            maxsum = max(maxsum, currentsum)
        return maxsum
