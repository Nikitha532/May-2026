class Solution:
    def longestCommonPrefix(self, arr1: List[int], arr2: List[int]) -> int:

        #Brute force approach
        
        longest = 0
        prefixes = set()

        for num in arr1 :
            s = str(num)
            for i in range(1, len(s)+1) :
                prefixes.add(s[:i])
        
        for num in arr2:
            s = str(num)
            for i in range(1, len(s)+1) :
                prefix = s[:i]

                if prefix in prefixes :
                    longest = max(longest, len(prefix))
        
        return longest

